# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
VITE_APP_ID=talk-to-my-lawyer

# ─── Database (Supabase / Postgres) ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...   # "anon public" key
VITE_SUPABASE_ANON_KEY=eyJ...          # same as above (legacy alias)

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Get from: https://dashboard.stripe.com/webhooks (add Railway URL as endpoint)
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Resend (email) ───────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── Upstash Redis (rate limiting) ────────────────────────────────────────────
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ─── AI ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
PERPLEXITY_API_KEY=pplx-...

# ─── n8n (optional) ───────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=https://your-n8n.com/webhook/...
N8N_CALLBACK_SECRET=change-me

# ─── Sentry (optional) ────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
VITE_SENTRY_DSN=https://...@sentry.io/...
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project

# ─── Manus / Forge (internal, leave blank if unused) ─────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
OWNER_OPEN_ID=
