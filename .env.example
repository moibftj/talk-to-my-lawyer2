# ─── Database ───────────────────────────────────────────────────────────────
# Supabase PostgreSQL connection string (required)
SUPABASE_DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
# Alternative variable name (either works)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ─── Supabase Auth ──────────────────────────────────────────────────────────
# Required — from Supabase project settings > API
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Frontend Supabase keys (for Realtime subscriptions)
VITE_SUPABASE_URL=https://[project-ref].supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
# Alternative name also accepted:
# VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...

# ─── Authentication ─────────────────────────────────────────────────────────
# Supabase UID of the owner account (auto-promoted to admin on first login)
OWNER_OPEN_ID=
# JWT secret for legacy session cookies (still required)
JWT_SECRET=a-long-random-secret-string

# ─── AI Pipeline ────────────────────────────────────────────────────────────
# Anthropic Claude — required for drafting and assembly stages
ANTHROPIC_API_KEY=sk-ant-...
# Perplexity — required for research stage (falls back to Claude if missing)
PERPLEXITY_API_KEY=pplx-...
# OpenAI — optional, currently unused (legacy)
# OPENAI_API_KEY=sk-...

# ─── Stripe Payments ────────────────────────────────────────────────────────
# Required for payment processing
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Publishable key is exposed to frontend via Vite
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ─── Email (Resend) ─────────────────────────────────────────────────────────
# Required for all transactional emails
RESEND_API_KEY=re_...
# Defaults to noreply@talktomylawyer.com if not set
RESEND_FROM_EMAIL=noreply@talktomylawyer.com

# ─── Rate Limiting (Upstash Redis) ──────────────────────────────────────────
# Optional — rate limiting is disabled (fail-open) if not set
UPSTASH_REDIS_REST_URL=https://[project].upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ─── Error Tracking (Sentry) ────────────────────────────────────────────────
# Optional — Sentry is disabled if not set
SENTRY_DSN=https://[key]@[org].ingest.sentry.io/[project]
VITE_SENTRY_DSN=https://[key]@[org].ingest.sentry.io/[project]
SENTRY_ORG=
SENTRY_PROJECT=

# ─── n8n Automation (optional) ──────────────────────────────────────────────
# Only needed if using n8n for pipeline orchestration
N8N_WEBHOOK_URL=
N8N_CALLBACK_SECRET=

# ─── App Config ─────────────────────────────────────────────────────────────
# Canonical domain used in email links
APP_BASE_URL=https://www.talk-to-my-lawyer.com
PORT=3000
NODE_ENV=development

# ─── Internal / Legacy ──────────────────────────────────────────────────────
# Manus built-in API (internal tooling, not needed externally)
BUILT_IN_FORGE_API_KEY=
BUILT_IN_FORGE_API_URL=
VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
# Cron trigger secret for draft reminder emails
CRON_SECRET=
